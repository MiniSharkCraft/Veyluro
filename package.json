{
  "name": "messmini",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "description": "Mini Messenger - Multi-platform E2EE chat. CongMC Dev Team.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "dev:mobile:legacy": "npm run start --workspace=apps/mobile-legacy",
    "setup:server": "./scripts/setup-server.sh",
    "setup:app": "./scripts/setup-app.sh",
    "build": "npm run --workspaces --if-present build",
    "build:web": "npm run build --workspace=apps/web",
    "type-check": "npm run --workspaces --if-present type-check",
    "lint": "npm run --workspaces --if-present lint",
    "test": "npm run --workspaces --if-present test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
