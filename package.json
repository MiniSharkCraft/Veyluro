{
  "name": "messmini",
  "version": "0.1.0",
  "private": true,
  "description": "Mini Messenger - Multi-platform E2EE chat. CongMC Dev Team.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "cd apps/mobile && node ../../node_modules/.bin/expo start",
    "build": "turbo build",
    "build:web": "npm run build --workspace=apps/web",
    "type-check": "turbo type-check",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
