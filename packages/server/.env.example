# Bắt buộc — generate bằng: openssl rand -hex 32
JWT_SECRET=your_64_char_hex_here

# Bắt buộc — AES-256-GCM key cho mã hóa email trong DB
DB_ENCRYPTION_KEY=your_64_char_hex_here

# Bắt buộc — HMAC-SHA256 key cho email search token
DB_HMAC_KEY=your_64_char_hex_here

# OAuth — lấy từ Google Cloud Console + Meta Developers
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://api.your-domain.com/api/auth/google/callback
OAUTH_APP_REDIRECT=amoon-eclipse://auth
FACEBOOK_APP_ID=1234567890

# Tùy chọn
PORT=8080
DB_DSN=user:pass@tcp(127.0.0.1:3306)/messmini?parseTime=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:34115,https://app.your-domain.com
ENV=development

# Cloudflare R2 — avatar upload (multipart max 25MB)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=amoon-uploads
R2_PUBLIC_BASE_URL=https://cdn.your-domain.com
R2_WARN_BYTES=6442450944
R2_BLOCK_BYTES=7516192768
# Bootstrap usage theo dashboard (bytes), ví dụ 7GB => 7516192768
R2_USAGE_SEED_BYTES=0

# Redis (optional) — distributed rate limit cho multi-instance
REDIS_URL=redis://default:password@127.0.0.1:6379/0
REDIS_PREFIX=amoon
