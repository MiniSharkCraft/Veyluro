# Bắt buộc — generate bằng: openssl rand -hex 32
JWT_SECRET=your_64_char_hex_here

# Bắt buộc — AES-256-GCM key cho mã hóa email trong DB
DB_ENCRYPTION_KEY=your_64_char_hex_here

# Bắt buộc — HMAC-SHA256 key cho email search token
DB_HMAC_KEY=your_64_char_hex_here

# OAuth — lấy từ Google Cloud Console + Meta Developers
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
FACEBOOK_APP_ID=1234567890

# Tùy chọn
PORT=8080
DB_PATH=./data/amoon.db
ALLOWED_ORIGINS=http://localhost:8081,https://amoon-eclipse.fly.dev
ENV=development
