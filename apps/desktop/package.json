{
  "name": "@messmini/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AMoon Eclipse Desktop",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @messmini/web dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "pnpm --filter @messmini/web build && electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "dev.congmc.amoon",
    "productName": "AMoon Eclipse",
    "copyright": "CongMC Dev Team",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web-dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
