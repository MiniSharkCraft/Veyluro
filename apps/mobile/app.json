{
  "expo": {
    "name": "Veyluro",
    "slug": "veyluro",
    "scheme": "veyluro",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08080F"
      },
      "package": "com.amoon.eclipse"
    },
    "ios": {
      "bundleIdentifier": "com.amoon.eclipse",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to secure your encryption keys",
        "NSCameraUsageDescription": "Used for video calls",
        "NSMicrophoneUsageDescription": "Used for voice and video calls"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "./plugins/withIntegrity"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "3f9599e5-2923-4d3e-85cc-7c27f102da44"
      }
    }
  }
}
