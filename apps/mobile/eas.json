{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "resourceClass": "medium"
    },
    "preview": {
      "distribution": "internal",
      "resourceClass": "medium",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://amoon-eclipse.fly.dev",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "508238156590-8blnr5tj5e537b1010u8aeshdbekhb0r.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "508238156590-jjvnimkhid7vdhf9h4umi9aa98mrqht6.apps.googleusercontent.com"
      }
    },
    "production": {
      "resourceClass": "medium",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://amoon-eclipse.fly.dev",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "508238156590-8blnr5tj5e537b1010u8aeshdbekhb0r.apps.googleusercontent.com",
        "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "508238156590-jjvnimkhid7vdhf9h4umi9aa98mrqht6.apps.googleusercontent.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
